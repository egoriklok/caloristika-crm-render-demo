# Copy this file to .env.local and fill only server-side values.
# Do not send .env.local to clients or public chats.

CRM_ACCESS_KEY=
CUSTOMER_PORTAL_SHARED_ACCESS_CODE=
PUBLIC_BASE_URL=
PORT=3011
HOST=0.0.0.0
CRM_NEXT_MODE=start
LUNCH_UP_CRM_DB_PATH=/app/data/lunch_up_crm.sqlite
LUNCH_UP_SQLITE_BUSY_TIMEOUT_MS=5000
LUNCH_UP_SQLITE_MMAP_SIZE=268435456
LUNCH_UP_SQLITE_WAL=1
PERF_BASE_URL=http://127.0.0.1:3011

# Render API automation. Keep RENDER_API_KEY local only; never paste it into chat.
RENDER_API_KEY=
RENDER_OWNER_ID=

# AI agent runtime. Default is offline: CRM writes deterministic recommendations without external model calls.
# Choose one provider: offline, paperclip, hermes, openclaw, omniroute, openai.
AGENT_LLM_PROVIDER=offline
AGENT_LLM_ENABLED=0
AGENT_WORKER_ID=lunch-up-agent-worker-1
AGENT_ALLOWED_CODES=
AGENT_MAX_TASKS_PER_RUN=3
AGENT_MAX_ATTEMPTS=3
AGENT_POLL_INTERVAL_MS=10000
AGENT_LLM_TIMEOUT_MS=45000
AGENT_LLM_MODEL=
# Remote worker mode: run this on a VPS, let it pull protected tasks from Render CRM.
REMOTE_CRM_BASE_URL=
REMOTE_CRM_ACCESS_KEY=

# Optional legacy OpenAI provider. Keep OPENAI_API_KEY server-side only.
OPENAI_API_KEY=
OPENAI_AGENT_MODEL=gpt-4.1-mini

# Paperclip provider. Use either an HTTP endpoint or a local command that reads JSON from stdin and returns JSON to stdout.
PAPERCLIP_AGENT_ENDPOINT=
PAPERCLIP_AGENT_COMMAND=
PAPERCLIP_API_KEY=
PAPERCLIP_AGENT_MODEL=

# Hermes provider. Use either Hermes gateway/API endpoint or a local command.
HERMES_AGENT_ENDPOINT=
HERMES_AGENT_COMMAND=
HERMES_API_KEY=
HERMES_AGENT_MODEL=

# OpenClaw provider. Use either OpenClaw gateway endpoint or a local command.
OPENCLAW_AGENT_ENDPOINT=
OPENCLAW_GATEWAY_URL=
OPENCLAW_AGENT_COMMAND=
OPENCLAW_API_KEY=
OPENCLAW_AGENT_MODEL=

# OmniRoute/OmniRouter provider. On the VPS, point this to local OmniRouter, not to Render localhost.
OMNIROUTER_BASE_URL=http://127.0.0.1:18790/v1
OMNIROUTER_API_KEY=
OMNIROUTER_MODEL=
OMNIROUTER_AGENT_ENDPOINT=
OMNIROUTER_AGENT_COMMAND=
OMNIROUTE_BASE_URL=
OMNIROUTE_API_KEY=
OMNIROUTE_MODEL=
OMNIROUTE_AGENT_ENDPOINT=
OMNIROUTE_AGENT_COMMAND=

TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_MANAGER_CHAT_ID=
TELEGRAM_BOT_DISPLAY_NAME=Lunch Up заказы
TELEGRAM_BOT_SUGGESTED_USERNAME=lunch_up_orders_bot
TELEGRAM_BOT_DESCRIPTION=Каталог Lunch Up для юридических лиц: кабинет, корзина и web-заказы.
TELEGRAM_BOT_SHORT_DESCRIPTION=Каталог, корзина и B2B-заказы Lunch Up.
TELEGRAM_MENU_BUTTON_TEXT=Lunch Up заказ
# Optional: BotFather /newapp short name for direct links like https://t.me/<bot>/<short>?startapp=order.
TELEGRAM_MINIAPP_SHORT_NAME=
# QA only: skip outgoing Telegram API calls while still validating signed Mini App initData.
TELEGRAM_OUTBOUND_DISABLED=

DGIS_API_KEY=
DADATA_API_KEY=
# QA/proxy only. Leave empty to use official 2GIS/DaData endpoints.
DGIS_API_BASE_URL=
DADATA_API_BASE_URL=

APIFY_TOKEN=
APIFY_DEFAULT_RESEARCH_ACTOR_ID=
EXTERNAL_ORDER_WEBHOOK_URL=
EXTERNAL_ORDER_WEBHOOK_TOKEN=
EXTERNAL_ORDER_WEBHOOK_PROVIDER=

# Use only for local browser testing outside Telegram.
MINIAPP_DEMO_MODE=
